# ---------------------------------------------------------------------------
# Pro Response configuration. Copy to `.env` and fill in.
# Every value has a sensible default except the credentials.
# ---------------------------------------------------------------------------

# --- Model provider --------------------------------------------------------
# Which backend to use: openai | anthropic | openai-compatible
PRO_PROVIDER=openai

# Model id. Leave blank to use the provider's default
# (openai -> gpt-5-mini, anthropic -> claude-sonnet-5).
PRO_MODEL=

# Default tone when the user hasn't chosen one.
# professional | friendly | concise | expand | formal | casual | grammar |
# soften | assertive | bullets | summarize | simplify | emojify | translate
PRO_DEFAULT_TONE=professional

# Generation controls.
PRO_TEMPERATURE=0.3
PRO_MAX_TOKENS=1024
PRO_MAX_INPUT_CHARS=6000

# Per-user rate limit (requests/minute). 0 disables limiting.
PRO_RATE_LIMIT_PER_MINUTE=20

PRO_LOG_LEVEL=INFO

# --- Credentials -----------------------------------------------------------
# OpenAI (used by the `openai` and `openai-compatible` providers).
OPENAI_API_KEY=

# Anthropic (used by the `anthropic` provider).
ANTHROPIC_API_KEY=

# For the `openai-compatible` provider (Azure OpenAI, Groq, OpenRouter,
# Together, Ollama, vLLM, ...). Example: https://api.groq.com/openai/v1
# PRO_BASE_URL=

# Optional OpenAI organization id.
# OPENAI_ORG=

# --- Slack -----------------------------------------------------------------
# Bot token (xoxb-...). Required.
SLACK_BOT_TOKEN=

# Connection mode: socket (recommended, no public URL) or http.
SLACK_MODE=socket

# App-level token (xapp-...). Required for Socket Mode.
SLACK_APP_TOKEN=

# Signing secret. Required for HTTP mode.
SLACK_SIGNING_SECRET=

# HTTP mode bind address/port (ignored in Socket Mode).
SERVICE_IP=0.0.0.0
SERVICE_PORT=3000
